DATABASE_URL=postgresql://user:password@localhost:5432/ecommerce
BETTER_AUTH_SECRET=generate-a-long-random-secret
BETTER_AUTH_URL=http://localhost:3000

# Required in production. Locally, mock checkout is used when unset
# (or set ALLOW_MOCK_CHECKOUT=true to force mock even with NODE_ENV=production).
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Dev-only: allow destructive db:seed against non-local databases
# ALLOW_DESTRUCTIVE_SEED=true
# ALLOW_MOCK_CHECKOUT=true
